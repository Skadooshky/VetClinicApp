<Window x:Class="VetClinic.App.Views.AnimalEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animal Editor" Height="400" Width="600">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="Name:" Grid.Row="0" Grid.Column="0" Margin="4" />
        <TextBox Text="{Binding Name}" Grid.Row="0" Grid.Column="1" Margin="4" />

        <TextBlock Text="Type:" Grid.Row="1" Grid.Column="0" Margin="4" />
        <TextBox Text="{Binding Type}" Grid.Row="1" Grid.Column="1" Margin="4" />

        <TextBlock Text="Breed:" Grid.Row="2" Grid.Column="0" Margin="4" />
        <TextBox Text="{Binding Breed}" Grid.Row="2" Grid.Column="1" Margin="4" />

        <TextBlock Text="Sex:" Grid.Row="3" Grid.Column="0" Margin="4" />
        <ComboBox SelectedItem="{Binding Sex}" Grid.Row="3" Grid.Column="1" Margin="4">
            <ComboBoxItem Content="Male"/>
            <ComboBoxItem Content="Female"/>
            <ComboBoxItem Content="Unknown"/>
        </ComboBox>

        <TextBlock Text="Owner:" Grid.Row="4" Grid.Column="0" Margin="4" />

        <ComboBox ItemsSource="{Binding Customers}"
          SelectedValue="{Binding SelectedCustomerId, Mode=TwoWay}"
          SelectedValuePath="Id"
          Grid.Row="4" Grid.Column="1" Margin="4">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                <Run Text="{Binding Surname}" /><Run Text=", " /><Run Text="{Binding FirstName}" />
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="4">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="75" Margin="4"/>
            <Button Content="Save" Command="{Binding SaveCommand}" Width="75" Margin="4"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}" Visibility="{Binding IsEditing}" Width="75" Margin="4"/>
        </StackPanel>
    </Grid>
</Window>
